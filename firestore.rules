rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/user/$(request.auth.uid));
    }

    function userRole() {
      return isSignedIn() ? userDoc().data.role : null;
    }

    function isWarehouse() {
      return isSignedIn() && userRole() == 'warehouse';
    }

    function isDriver() {
      return isSignedIn() && userRole() == 'driver';
    }

    function isLogistica() {
      return isSignedIn() && userRole() == 'logistic';
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role in ['admin', 'ADMIN', 'Administrador', 'administrador'];
    }

    function canManageResponsables() {
      return isSignedIn() && userDoc().data.role in ['admin', 'dispatcher', 'manager', 'logistic'];
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /user/{uid} {
      allow read, write: if isSignedIn();
    }

    match /interactions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.actor.id == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /loads/{id} {
      allow read: if isSignedIn() && (!isDriver() || resource.data.chofer == request.auth.uid);
      allow create: if isSignedIn() && !isDriver();
      allow delete: if isLogistica() || isAdmin();
      allow update: if isSignedIn() && (
        !isDriver() ||
        (
          resource.data.chofer == request.auth.uid &&
          (
            request.resource.data.estado_viaje == 'Viajando' ||
            (
              resource.data.estado_viaje == 'Viajando' &&
              request.resource.data.estado_viaje in ['Entregado', 'Cancelado']
            )
          ) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'estado_viaje',
            'nombre',
            'modificado_por',
            'fecha_modificacion',
            'updatedAt'
          ])
        )
      );
    }

    match /pallets/{id} {
      allow read, write: if isSignedIn();
    }

    match /ships/{id} {
      allow read, write: if isSignedIn();
    }

    match /companies/{id} {
      allow read, write: if isSignedIn();
    }

    match /consignees/{id} {
      allow read, write: if isSignedIn();
    }

    match /locations/{id} {
      allow read, write: if isSignedIn();
    }

    match /cargo_types/{id} {
      allow read, write: if isSignedIn();
    }

    match /responsables/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if canManageResponsables();
    }

    match /messages/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isLogistica();
      match /reads/{uid} {
        allow read: if isLogistica() || (isSignedIn() && uid == request.auth.uid);
        allow create, update: if isSignedIn() &&
          uid == request.auth.uid &&
          request.resource.data.user_id == request.auth.uid;
        allow delete: if false;
      }
    }

    match /merma/{id} {
      allow read, write: if isSignedIn();
    }

    match /app_options/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /informes_carga/{id} {
      allow read, write: if isSignedIn();
    }

    match /peticiones/{id} {
      function peticionesDisabled() {
        return exists(/databases/$(database)/documents/app_options/features) &&
          get(/databases/$(database)/documents/app_options/features).data.disable_peticiones == true;
      }
      allow read: if isAdmin() || (!peticionesDisabled() && isSignedIn());
      allow create: if isAdmin() || (!peticionesDisabled() && isSignedIn() && userRole() in ['dispatcher', 'oficina', 'office']);
      allow update: if isAdmin() || (!peticionesDisabled() && isSignedIn() && userRole() in ['admin', 'logistic']);
      allow delete: if isAdmin();
    }

    match /productos/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && !isWarehouse();
    }
  }
}
